using System;
using System.IO;

namespace UnifiedProject
{
    public static class BinaryMathTasks
    {
        // Метод для создания бинарного файла с числами
        public static void CreateBinaryNumbersFile(string filePath)
        {
            // Набор тестовых данных:
            // 6 (удв. нечет), 10 (удв. нечет), 8 (четное, не подходит), 7 (нечет), 14 (удв. нечет)
            int[] numbers = { 6, 10, 8, 7, 14, 20, 22 };

            using (BinaryWriter writer = new BinaryWriter(File.Open(filePath, FileMode.Create)))
            {
                foreach (int num in numbers)
                {
                    writer.Write(num);
                }
            }
            Console.WriteLine("Бинарный файл чисел создан: {0}", filePath);
        }

        // Метод для вывода содержимого бинарного файла (для сравнения)
        public static void PrintBinaryNumbers(string filePath)
        {
            if (!File.Exists(filePath)) return;

            Console.Write("Содержимое файла: ");
            using (BinaryReader reader = new BinaryReader(File.Open(filePath, FileMode.Open)))
            {
                // Читаем, пока не достигнем конца потока
                while (reader.BaseStream.Position < reader.BaseStream.Length)
                {
                    int num = reader.ReadInt32();
                    Console.Write(num + " ");
                }
            }
            Console.WriteLine();
        }

        // Метод для поиска количества удвоенных нечетных чисел
        public static int CountDoubleOddsBinary(string filePath)
        {
            if (!File.Exists(filePath)) return 0;

            int count = 0;
            using (BinaryReader reader = new BinaryReader(File.Open(filePath, FileMode.Open)))
            {
                while (reader.BaseStream.Position < reader.BaseStream.Length)
                {
                    int num = reader.ReadInt32();

                    // Проверка условия: 
                    // 1. Число четное (num % 2 == 0)
                    // 2. Результат деления на 2 - нечетный ((num / 2) % 2 != 0)
                    if (num % 2 == 0 && (num / 2) % 2 != 0)
                    {
                        count++;
                    }
                }
            }
            return count;
        }
    }

    class Program
    {
        static void Main()
        {
            string fileName = "numbers.dat";

            // 1. Создаем файл
            BinaryMathTasks.CreateBinaryNumbersFile(fileName);

            // 2. Выводим числа для проверки глазами
            BinaryMathTasks.PrintBinaryNumbers(fileName);

            // 3. Считаем результат
            int result = BinaryMathTasks.CountDoubleOddsBinary(fileName);

            Console.WriteLine("\nКоличество удвоенных нечетных чисел: {0}", result);
            
            // В нашем примере это: 6, 10, 14, 22. Итого: 4.
            
            Console.ReadKey();
        }
    }
}
